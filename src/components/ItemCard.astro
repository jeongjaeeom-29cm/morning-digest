---
import type { CollectionEntry } from 'astro:content';
interface Props { item: CollectionEntry<'items'> }
const { item } = Astro.props;
const d = item.data;
const dateLabel = new Date(d.publishedAt).toISOString().slice(0, 10);
const base = import.meta.env.BASE_URL;
const categoryFallback = `${base}/fallbacks/${d.source.category}.svg`;
const defaultFallback = `${base}/fallbacks/default.svg`;
const imgSrc = d.thumbnail ?? categoryFallback;
---
<article class="card" data-item-id={d.id}>
  <img
    src={imgSrc}
    alt=""
    loading="lazy"
    width="640"
    style="width:100%;max-width:100%;border-radius:8px;aspect-ratio:16/9;object-fit:cover;"
    data-category-fallback={categoryFallback}
    data-default-fallback={defaultFallback}
    onerror="
      if (this.src !== this.dataset.categoryFallback) { this.src = this.dataset.categoryFallback; return; }
      if (this.src !== this.dataset.defaultFallback) { this.src = this.dataset.defaultFallback; return; }
      this.onerror = null;
    "
  />
  <h3 style="margin:8px 0 4px;"><a href={d.url} rel="noopener noreferrer" target="_blank">{d.title}</a></h3>
  <div style="color:var(--muted);font-size:13px;margin-bottom:8px;">
    <span>{d.source.name}</span> · <span>{dateLabel}</span>
  </div>
  <p style="margin:0 0 8px;">{d.summary}</p>
  <div>
    {d.tags.map((t: string) => <a class="tag" href={`${base}/tags/${t}`}>{t}</a>)}
  </div>
</article>
